# ╔═══════════════════════════════════════════════════════════════════╗
# ║  Smart Campus Net-Zero Command Center — Environment Variables   ║
# ║  Copy this file to .env for local development                   ║
# ║  On Railway, set these in the Variables tab of your service.    ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ── MongoDB Connection (optional — app falls back to in-memory) ────
MONGO_URI=mongodb://mongo:YOUR_PASSWORD@YOUR_HOST:PORT/?authSource=admin&directConnection=true
MONGO_DB=smart_campus

# ── Flask / Server ─────────────────────────────────────────────────
# PORT is auto-injected by Railway — do NOT set it manually there.
# For local dev you can use FLASK_PORT instead.
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Sustainability KPI Defaults ────────────────────────────────────
# These are fallback values used when no manual input has been saved
# via the Data Management page.
CAMPUS_TOTAL_STUDENTS=12000
CAMPUS_AREA_M2=120000
BASELINE_PEAK_KW=2400
GRID_EMISSION_FACTOR_KG_PER_KWH=0.82
LOAD_FACTOR_ASSUMPTION=0.45
